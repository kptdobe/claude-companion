#!/bin/sh
# claude-companion-hook <state>
#
# Invoked by Claude Code hooks. Reads the hook payload (JSON) on stdin and
# writes a tiny per-session state file the menu bar app watches:
#   ~/.claude/companion-state/<session_id>.json
#
# <state> is one of: thinking | waiting | idle
# It is passed as the only argument from the hook configuration so this script
# stays trivial and fast (no per-event JSON branching here).

STATE="${1:-unknown}"
DIR="${CLAUDE_COMPANION_STATE_DIR:-$HOME/.claude/companion-state}"
mkdir -p "$DIR" 2>/dev/null

# Extract session_id / cwd / hook event from the stdin payload and write the
# state file. We use `python3 -c` (not a heredoc with `-`) so the piped JSON
# payload stays on stdin instead of being consumed as the program source.
# python3 ships with macOS Command Line Tools; fast and dependency-free.
python3 -c '
import sys, os, json, time
state, out_dir = sys.argv[1], sys.argv[2]
try:
    payload = json.load(sys.stdin)
except Exception:
    payload = {}
session_id = payload.get("session_id") or "unknown"

# Tools that block waiting for the user. A PreToolUse for one of these means
# Claude is waiting on you, not working. Keep in sync with SessionActivity
# .blockingTools in the Swift sources.
BLOCKING_TOOLS = {"AskUserQuestion", "ExitPlanMode"}

def last_assistant_text(path):
    # Return the most recent assistant message text from the JSONL transcript.
    # Reads only the tail so it stays fast on large transcripts.
    try:
        with open(path, "rb") as f:
            f.seek(0, 2)
            f.seek(max(0, f.tell() - 262144))
            data = f.read().decode("utf-8", "replace")
    except Exception:
        return ""
    for line in reversed(data.splitlines()):
        try:
            obj = json.loads(line)
        except Exception:
            continue
        if obj.get("type") != "assistant":
            continue
        content = (obj.get("message") or {}).get("content")
        if isinstance(content, list):
            text = " ".join(b.get("text", "") for b in content
                            if isinstance(b, dict) and b.get("type") == "text")
        elif isinstance(content, str):
            text = content
        else:
            text = ""
        if text.strip():
            return text
    return ""

event = payload.get("hook_event_name")
if event == "PreToolUse" and payload.get("tool_name") in BLOCKING_TOOLS:
    state = "waiting"
elif event == "Stop":
    # Turn ended: if Claude'"'"'s closing message asks the user something it is
    # waiting on you (orange); otherwise it is done (green). Mirrors
    # SessionActivity.looksLikeQuestion in the Swift sources.
    if "?" in last_assistant_text(payload.get("transcript_path") or ""):
        state = "waiting"

record = {
    "sessionId": session_id,
    "state": state,
    "event": payload.get("hook_event_name"),
    "cwd": payload.get("cwd"),
    "ts": time.time(),
}
# Atomic write: temp file + rename, so the watcher never reads a half-written file.
path = os.path.join(out_dir, session_id + ".json")
tmp = path + ".tmp"
with open(tmp, "w") as f:
    json.dump(record, f)
os.replace(tmp, path)

# Optional debug log: set CLAUDE_COMPANION_DEBUG=1 to record every hook
# invocation to companion-state/_events.log (handy for diagnosing what fires).
if os.environ.get("CLAUDE_COMPANION_DEBUG", "0") == "1":
    try:
        with open(os.path.join(out_dir, "_events.log"), "a") as lf:
            lf.write("%.0f %s %s tool=%s -> %s\n" % (
                time.time(), session_id[:8],
                payload.get("hook_event_name"), payload.get("tool_name"), state))
    except Exception:
        pass
' "$STATE" "$DIR"

# Never block Claude Code: always succeed.
exit 0
